---
// Hero <picture> with AVIF/WebP/JPG srcset, hosted on R2.
//
// Props:
//   slot       — base filename (e.g. "p05-sauer1-detail")
//   widths     — available widths e.g. [800, 1200, 1920, 2560]
//   alt        — alt text
//   sizes      — CSS sizes attribute (default: container-friendly)
//   aspectRatio — optional CSS aspect-ratio (e.g. "4/3")
//   priority   — true → fetchpriority=high + loading=eager (above the fold)
//   bleed      — full | inset (default: inset)

interface Props {
  slot: string;
  widths: number[];
  alt: string;
  sizes?: string;
  aspectRatio?: string;
  priority?: boolean;
  bleed?: 'full' | 'inset';
  v?: string;
}

const R2 = 'https://pub-45145834ff2b45db8a585cff5b669e13.r2.dev';
const {
  slot,
  widths,
  alt,
  sizes = '(max-width: 820px) 92vw, 70vw',
  aspectRatio,
  priority = false,
  bleed = 'inset',
  v = '1777828698',
} = Astro.props;

const sortedWidths = [...widths].sort((a, b) => a - b);
const set = (ext: string) =>
  sortedWidths.map(w => `${R2}/${slot}-${w}w.${ext}?v=${v} ${w}w`).join(', ');
const fallbackW = sortedWidths[Math.min(2, sortedWidths.length - 1)];
---

<figure class:list={['hero', `hero--${bleed}`]} style={aspectRatio ? `aspect-ratio:${aspectRatio}` : undefined}>
  <picture>
    <source type="image/avif" srcset={set('avif')} sizes={sizes} />
    <source type="image/webp" srcset={set('webp')} sizes={sizes} />
    <img
      src={`${R2}/${slot}-${fallbackW}w.jpg?v=${v}`}
      srcset={set('jpg')}
      sizes={sizes}
      alt={alt}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      fetchpriority={priority ? 'high' : 'auto'}
    />
  </picture>
  <slot name="caption" />
</figure>

<style>
  .hero {
    margin: 0;
    background: var(--paper-2);
    border: 1px solid var(--hair);
    overflow: hidden;
  }
  .hero img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero--full {
    margin-inline: calc((100vw - 100%) / -2);
    width: 100vw;
    border-inline: 0;
  }
</style>
