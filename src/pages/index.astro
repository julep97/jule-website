---
import Editorial from '../layouts/Editorial.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Editorial title="jule plaehn — textile design /26">
  <article class="hero">
    <p class="eyebrow">— textile design /26 · krefeld</p>
    <h1 class="display">jule plaehn</h1>
    <p class="lead">
      Drei Projekte zwischen Material, Raum und Symbol —
      <em>Nutritions</em>, <em>(Objekt) siebzig</em> und <em>Freie Arbeiten</em>.
    </p>

    <nav class="hero-nav" aria-label="Projekte">
      <a href={`${base}/work/sauer-1`} class="hero-link">
        <span class="num">/01</span>
        <span class="title">Entwurf Sauer 1</span>
        <span class="meta">— Filz · Akustik · Nutritions</span>
      </a>
      <a href={`${base}/print`} class="hero-link">
        <span class="num">/00</span>
        <span class="title">Vollständiges Portfolio</span>
        <span class="meta">— Print-Ansicht, alle 30 Seiten</span>
      </a>
    </nav>
  </article>
</Editorial>

<style>
  .hero {
    max-width: 60rem;
    margin: 0 auto;
    padding: var(--gap-xl) var(--gap-md);
  }
  .hero .eyebrow { margin-bottom: var(--gap-md); }
  .hero h1.display { margin-bottom: var(--gap-md); }
  .hero .lead { max-width: 36ch; margin-bottom: var(--gap-xl); color: var(--ink); }
  .hero em { font-style: italic; }

  .hero-nav { display: flex; flex-direction: column; gap: 0; }
  .hero-link {
    display: grid; grid-template-columns: 4rem 1fr auto; align-items: baseline;
    gap: var(--gap-md);
    padding: var(--gap-md) 0;
    border-top: 1px solid var(--hair);
    transition: background .15s ease;
  }
  .hero-link:last-child { border-bottom: 1px solid var(--hair); }
  .hero-link:hover, .hero-link:focus-visible {
    background: var(--paper);
    outline: none;
  }
  .hero-link .num { font-family: var(--font-mono); font-size: .8rem; color: var(--contrast); }
  .hero-link .title { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.25rem); font-style: italic; }
  .hero-link .meta { font-family: var(--font-mono); font-size: .8rem; color: var(--contrast); }

  @media (max-width: 640px) {
    .hero { padding: var(--gap-lg) var(--gap-sm); }
    .hero-link { grid-template-columns: 3rem 1fr; }
    .hero-link .meta { grid-column: 2; color: var(--contrast); }
  }
</style>
