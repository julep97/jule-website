---
import Editorial from '../../layouts/Editorial.astro';
import Hero from '../../components/Hero.astro';
import SideCaption from '../../components/SideCaption.astro';
import ProjectCode from '../../components/ProjectCode.astro';
import { projectBySlug } from '../../data/projects';

const project = projectBySlug('sauer-2')!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Editorial
  title={`Entwurf ${project.title} — jule plaehn`}
  description={project.lead}
  ogImage={`https://pub-45145834ff2b45db8a585cff5b669e13.r2.dev/${project.hero}-1920w.jpg`}
>
  <article class="work">

    <header class="work-head">
      <p class="eyebrow">{project.eyebrow}</p>
      <h1 class="display">
        <em>Sauer</em> 2
      </h1>
      <ProjectCode num={project.num} title={project.meta} />
    </header>

    <section class="intro">
      <p class="lead">
        Frei genähte Kreise, mit Schafswollresten gefüllt — die <em>Sauer</em>-Form
        als Blase.
      </p>
    </section>

    <!-- 3-image gallery: material variations -->
    <section class="gallery">
      <SideCaption num="01" title="Material">
        <p>
          Weiter festgehalten an der Form <em>Sauer</em> wurden hier frei
          genähte Kreise mit Schafswolle gefüllt.
        </p>
        <p>
          Aus unterschiedlichen Materialien realisiert.
        </p>
      </SideCaption>

      <div class="gallery-grid">
        <Hero
          slot="p07-sauer2-a"
          widths={[800, 1200, 1920, 2560]}
          alt="Schafswoll-Blasen aus festem hellbeigem Stoff genäht — Detail"
          aspectRatio="1/1"
          sizes="(max-width: 820px) 92vw, 30vw"
          priority
        />
        <Hero
          slot="p07-sauer2-b"
          widths={[800, 1200, 1920, 2560]}
          alt="Schafswoll-Blasen aus dunklem strukturiertem Stoff — Detail"
          aspectRatio="1/1"
          sizes="(max-width: 820px) 92vw, 30vw"
        />
        <Hero
          slot="p07-sauer2-d"
          widths={[800, 1200, 1920, 2560]}
          alt="Schafswoll-Blasen-Variation in dritter Materialvariante"
          aspectRatio="1/1"
          sizes="(max-width: 820px) 92vw, 30vw"
        />
      </div>
    </section>

    <!-- leuchtkasten installation: portrait image with side caption -->
    <section class="installation">
      <SideCaption num="02" title="Anwendung">
        <p>
          Mit Schafswollresten befüllte Blasen, gerahmt und <em>vor Leuchtkästen
          gespannt</em> — als Wandmodule über der Küchenzeile.
        </p>
      </SideCaption>
      <Hero
        slot="p08-sauer2-leuchtkasten"
        widths={[800, 1200, 1920]}
        alt="Küche mit drei gerahmten Sauer-2-Modulen vor Leuchtkästen-Pattern an der Wand"
        bleed="inset"
        sizes="(max-width: 820px) 92vw, 50vw"
      />
    </section>

    <footer class="work-foot">
      <a href={`${base}/`} class="back">← zurück</a>
      <a href={`${base}/work/sauer-1/`} class="next">
        ← Sauer 1
      </a>
      <a href={`${base}/print/#p8`} class="print-link">
        Print-Ansicht →
        <span class="meta">PDF {project.pdfPages}</span>
      </a>
    </footer>

  </article>
</Editorial>

<style>
  .work {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--gap-xl) var(--gap-md);
  }

  .work-head { margin-bottom: var(--gap-xl); }
  .work-head .eyebrow { margin-bottom: var(--gap-sm); }
  .work-head h1.display {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    margin-bottom: var(--gap-md);
  }
  .work-head h1 em { font-style: italic; }

  .intro {
    max-width: 36rem;
    margin: 0 auto var(--gap-xl);
    text-align: center;
  }
  .intro .lead { color: var(--ink); }
  .intro em { font-style: italic; color: var(--red-text); }

  /* gallery section: caption left, 3-img grid right */
  .gallery {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 3fr);
    gap: var(--gap-md) var(--gap-lg);
    align-items: start;
    margin-bottom: var(--gap-xl);
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--gap-sm);
  }

  /* installation section: caption left, portrait image right (matches PDF p9) */
  .installation {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: var(--gap-md) var(--gap-lg);
    align-items: start;
    margin-bottom: var(--gap-xl);
    max-width: 60rem;
    margin-inline: auto;
  }

  .work-foot {
    display: flex; justify-content: space-between; align-items: baseline;
    flex-wrap: wrap; gap: var(--gap-sm);
    padding-top: var(--gap-lg);
    border-top: 1px solid var(--hair);
    font-family: var(--font-mono); font-size: 0.85rem;
  }
  .work-foot a {
    color: var(--ink);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color .15s;
  }
  .work-foot a:hover, .work-foot a:focus-visible {
    border-color: var(--red); outline: none;
  }
  .work-foot .meta { margin-left: 0.5rem; color: var(--contrast); font-size: 0.75rem; }

  @media (max-width: 820px) {
    .work { padding: var(--gap-lg) var(--gap-sm); }
    .work-head { margin-bottom: var(--gap-lg); }
    .intro { margin-bottom: var(--gap-lg); }
    .gallery, .installation {
      grid-template-columns: 1fr;
      gap: var(--gap-md);
      margin-bottom: var(--gap-lg);
    }
    .gallery-grid {
      grid-template-columns: 1fr;
      gap: var(--gap-sm);
    }
  }
</style>
