---
import Editorial from '../../layouts/Editorial.astro';
import Hero from '../../components/Hero.astro';
import SideCaption from '../../components/SideCaption.astro';
import ProjectCode from '../../components/ProjectCode.astro';
import { projectBySlug } from '../../data/projects';

const project = projectBySlug('lachen')!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// PDF p.10 — material grid (PDF reading order: L1, R1, L2, R2, L3, R3)
const materialGrid = [
  { slot: 'p09-lachen-a', aspect: '3/4',
    alt: 'Aufrechte D-förmige Filzstücke in Reihen aufgestellt, mit Schatten auf weißem Untergrund — Perspektivansicht' },
  { slot: 'p09-lachen-b', aspect: '4/3',
    alt: 'D-förmige Filzstücke flach ausgelegt — Detail mit präzisen Lasercutter-Konturen' },
  { slot: 'p09-lachen-e', aspect: '3/4',
    alt: 'Hohle Filz-Vase, Blick von oben in die viereckige Form mit Wandcutouts' },
  { slot: 'p09-lachen-d', aspect: '3/4',
    alt: 'Vertikaler Filzstreifen mit zwei Ösen und einem Karabiner als Verbindungselement zwischen zwei Modulen' },
  { slot: 'p09-lachen-f', aspect: '3/4',
    alt: 'Sternförmig konzentrische Filzbögen — Blick von oben in eine zylindrische Konstruktion' },
  { slot: 'p09-lachen-c', aspect: '3/4',
    alt: 'Detailansicht einer vierwandigen Filz-Vase mit horizontalen Cutout-Reihen — Blick von oben hinein' },
];
---

<Editorial
  title={`Entwurf ${project.title} — jule plaehn`}
  description={project.lead}
  ogImage={`https://pub-45145834ff2b45db8a585cff5b669e13.r2.dev/${project.hero}-1200w.jpg`}
>
  <article class="work">

    <header class="work-head">
      <p class="eyebrow">{project.eyebrow}</p>
      <h1 class="display"><em>Lachen</em></h1>
      <ProjectCode num={project.num} title={project.meta} />
    </header>

    <section class="intro">
      <p class="lead">
        Filz-Ausarbeitungen, mit dem <em>Lasercutter</em> exakt zugeschnitten
        und mit der Hand frei nachgearbeitet — als Vase, Kerzenhalter oder
        Wandapplikation einsetzbar.
      </p>
    </section>

    <!-- material — caption + 6-image grid mirroring PDF p10 layout -->
    <section class="material">
      <SideCaption num="01" title="Material">
        <p>
          Eine exakte Ausarbeitung mit dem <em>Lasercutter</em> zugeschnitten,
          eine freie Ausarbeitung mit der Hand.
        </p>
        <p>
          Filz als Trägermaterial — ausgeschnitten, gefaltet und zu
          dreidimensionalen Objekten zusammengesetzt.
        </p>
      </SideCaption>

      <div class="material-grid">
        {materialGrid.map((img, i) => (
          <Hero
            slot={img.slot}
            widths={[800, 1200, 1920, 2560]}
            alt={img.alt}
            aspectRatio={img.aspect}
            sizes="(max-width: 820px) 92vw, 30vw"
            priority={i === 0}
          />
        ))}
      </div>
    </section>

    <!-- anwendung — wand portrait + caption/tisch + konzept -->
    <section class="application">
      <Hero
        slot="p10-lachen-wand"
        widths={[800, 1200]}
        alt="Vertikale Wandapplikation: gemusterter Filzstreifen, mit Ösen und Karabinern an einer Holzwand befestigt"
        aspectRatio="1/3"
        sizes="(max-width: 820px) 60vw, 22vw"
      />

      <div class="application-mid">
        <SideCaption num="02" title="Anwendung">
          <p>
            Als Installation auf dem Tisch — <em>Vase, Kerzenhalter</em>,
            jeweils mit einem Glas in der Mitte, oder Flaschenaufbewahrung.
          </p>
          <p>
            Durch Ösen und Karabiner flexibel <em>an der Wand
            anwendbar</em>.
          </p>
        </SideCaption>
        <Hero
          slot="p10-lachen-tisch"
          widths={[800, 1200, 1920]}
          alt="Filz-Lampion mit Glas in der Mitte auf einer Holz-Küchenarbeitsplatte vor weißer Fliesenwand"
          aspectRatio="11/6"
          sizes="(max-width: 820px) 92vw, 35vw"
        />
      </div>

      <Hero
        slot="p10-lachen-konzept"
        widths={[800, 1200, 1920]}
        alt="Konzeptbild: Person in einem Türrahmen mit darüber gerasterten roten Markierungen, die zukünftige Wandinstallation in Maßstab zeigen"
        aspectRatio="3/5"
        sizes="(max-width: 820px) 92vw, 28vw"
      />
    </section>

    <footer class="work-foot">
      <a href={`${base}/`} class="back">← zurück</a>
      <a href={`${base}/work/sauer-2/`} class="next">← Sauer 2</a>
      <a href={`${base}/print/#p10`} class="print-link">
        Print-Ansicht →
        <span class="meta">PDF {project.pdfPages}</span>
      </a>
    </footer>

  </article>
</Editorial>

<style>
  .work {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--gap-xl) var(--gap-md);
  }

  .work-head { margin-bottom: var(--gap-xl); }
  .work-head .eyebrow { margin-bottom: var(--gap-sm); }
  .work-head h1.display {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    margin-bottom: var(--gap-md);
  }
  .work-head h1 em { font-style: italic; }

  .intro {
    max-width: 38rem;
    margin: 0 auto var(--gap-xl);
    text-align: center;
  }
  .intro .lead { color: var(--ink); }
  .intro em { font-style: italic; color: var(--red-text); }

  /* material — caption left (1fr), grid right (4fr); 3 columns at desktop */
  .material {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 4fr);
    gap: var(--gap-md) var(--gap-lg);
    align-items: start;
    margin-bottom: var(--gap-xl);
  }
  .material-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--gap-sm);
    align-items: start;
  }

  /* anwendung — 3 columns: wand | (caption + tisch) | konzept */
  .application {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr) minmax(0, 1.2fr);
    gap: var(--gap-md) var(--gap-lg);
    align-items: start;
    margin-bottom: var(--gap-xl);
  }
  .application-mid {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .work-foot {
    display: flex; justify-content: space-between; align-items: baseline;
    flex-wrap: wrap; gap: var(--gap-sm);
    padding-top: var(--gap-lg);
    border-top: 1px solid var(--hair);
    font-family: var(--font-mono); font-size: 0.85rem;
  }
  .work-foot a {
    color: var(--ink);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color .15s;
  }
  .work-foot a:hover, .work-foot a:focus-visible {
    border-color: var(--red); outline: none;
  }
  .work-foot .meta { margin-left: 0.5rem; color: var(--contrast); font-size: 0.75rem; }

  @media (max-width: 1100px) {
    .material-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 820px) {
    .work { padding: var(--gap-lg) var(--gap-sm); }
    .work-head { margin-bottom: var(--gap-lg); }
    .intro { margin-bottom: var(--gap-lg); }
    .material, .application {
      grid-template-columns: 1fr;
      gap: var(--gap-md);
      margin-bottom: var(--gap-lg);
    }
    .material-grid {
      grid-template-columns: 1fr;
      gap: var(--gap-sm);
    }
  }
</style>
