---
import Editorial from '../../layouts/Editorial.astro';
import Hero from '../../components/Hero.astro';
import SideCaption from '../../components/SideCaption.astro';
import ProjectCode from '../../components/ProjectCode.astro';
import { projectBySlug } from '../../data/projects';

const project = projectBySlug('lachen')!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Editorial
  title={`Entwurf ${project.title} — jule plaehn`}
  description={project.lead}
  ogImage={`https://pub-45145834ff2b45db8a585cff5b669e13.r2.dev/${project.hero}-1200w.jpg`}
>
  <article class="work">

    <header class="work-head">
      <p class="eyebrow">{project.eyebrow}</p>
      <h1 class="display"><em>Lachen</em></h1>
      <ProjectCode num={project.num} title={project.meta} />
    </header>

    <section class="intro">
      <p class="lead">
        Filz-Ausarbeitungen, mit dem <em>Lasercutter</em> exakt zugeschnitten
        und mit der Hand frei nachgearbeitet — als Vase, Kerzenhalter oder
        Wandapplikation einsetzbar.
      </p>
    </section>

    <!-- material — caption + 2-img detail pair from PDF page 10 -->
    <section class="material">
      <SideCaption num="01" title="Material">
        <p>
          Eine exakte Ausarbeitung mit dem <em>Lasercutter</em> zugeschnitten,
          eine freie Ausarbeitung mit der Hand.
        </p>
        <p>
          Filz als Trägermaterial — ausgeschnitten, gefaltet und zu
          dreidimensionalen Objekten zusammengesetzt.
        </p>
      </SideCaption>

      <div class="material-pair">
        <Hero
          slot="p09-lachen-b"
          widths={[800, 1200, 1920, 2560]}
          alt="Filz-Ausarbeitungen mit Lasercutter zugeschnitten — Detail mit präzisen Kreis- und Bogenformen"
          aspectRatio="4/3"
          sizes="(max-width: 820px) 92vw, 45vw"
          priority
        />
        <Hero
          slot="p09-lachen-e"
          widths={[800, 1200, 1920, 2560]}
          alt="Frei mit der Hand zugeschnittene Filz-Ausarbeitung — dreidimensionales Objekt mit gefalteten Laschen"
          aspectRatio="3/4"
          sizes="(max-width: 820px) 92vw, 30vw"
        />
      </div>
    </section>

    <!-- anwendung — wand portrait + caption + tisch landscape -->
    <section class="application">
      <Hero
        slot="p10-lachen-wand"
        widths={[800, 1200]}
        alt="Vertikale Wandapplikation: gemusterter Filzstreifen, mit Ösen und Karabinern an einer Holzwand befestigt"
        aspectRatio="1/3"
        sizes="(max-width: 820px) 60vw, 22vw"
      />
      <div class="application-aside">
        <SideCaption num="02" title="Anwendung">
          <p>
            Als Installation auf dem Tisch — <em>Vase, Kerzenhalter</em>,
            jeweils mit einem Glas in der Mitte, oder Flaschenaufbewahrung.
          </p>
          <p>
            Durch Ösen und Karabiner flexibel <em>an der Wand
            anwendbar</em>.
          </p>
        </SideCaption>
        <Hero
          slot="p10-lachen-tisch"
          widths={[800, 1200, 1920]}
          alt="Filz-Lampion mit Glas in der Mitte auf einer Holz-Küchenarbeitsplatte vor weißer Fliesenwand"
          aspectRatio="11/6"
          sizes="(max-width: 820px) 92vw, 50vw"
        />
      </div>
    </section>

    <footer class="work-foot">
      <a href={`${base}/`} class="back">← zurück</a>
      <a href={`${base}/work/sauer-2/`} class="next">← Sauer 2</a>
      <a href={`${base}/print/#p10`} class="print-link">
        Print-Ansicht →
        <span class="meta">PDF {project.pdfPages}</span>
      </a>
    </footer>

  </article>
</Editorial>

<style>
  .work {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--gap-xl) var(--gap-md);
  }

  .work-head { margin-bottom: var(--gap-xl); }
  .work-head .eyebrow { margin-bottom: var(--gap-sm); }
  .work-head h1.display {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    margin-bottom: var(--gap-md);
  }
  .work-head h1 em { font-style: italic; }

  .intro {
    max-width: 38rem;
    margin: 0 auto var(--gap-xl);
    text-align: center;
  }
  .intro .lead { color: var(--ink); }
  .intro em { font-style: italic; color: var(--red-text); }

  /* material — caption left, 2-img pair right (4:3 + 3:4) */
  .material {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 3fr);
    gap: var(--gap-md) var(--gap-lg);
    align-items: start;
    margin-bottom: var(--gap-xl);
  }
  .material-pair {
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
    gap: var(--gap-sm);
    align-items: start;
  }

  /* application — tall wand portrait left, caption + tisch right */
  .application {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 3fr);
    gap: var(--gap-md) var(--gap-lg);
    align-items: start;
    margin-bottom: var(--gap-xl);
  }
  .application-aside {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .work-foot {
    display: flex; justify-content: space-between; align-items: baseline;
    flex-wrap: wrap; gap: var(--gap-sm);
    padding-top: var(--gap-lg);
    border-top: 1px solid var(--hair);
    font-family: var(--font-mono); font-size: 0.85rem;
  }
  .work-foot a {
    color: var(--ink);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color .15s;
  }
  .work-foot a:hover, .work-foot a:focus-visible {
    border-color: var(--red); outline: none;
  }
  .work-foot .meta { margin-left: 0.5rem; color: var(--contrast); font-size: 0.75rem; }

  @media (max-width: 820px) {
    .work { padding: var(--gap-lg) var(--gap-sm); }
    .work-head { margin-bottom: var(--gap-lg); }
    .intro { margin-bottom: var(--gap-lg); }
    .material, .application {
      grid-template-columns: 1fr;
      gap: var(--gap-md);
      margin-bottom: var(--gap-lg);
    }
    .material-pair {
      grid-template-columns: 1fr;
      gap: var(--gap-sm);
    }
  }
</style>
