---
// Master layout for the editorial site.
//
// Props:
//   title       — page <title> + og:title
//   description — meta description + og:description
//   ogImage     — full URL of OG image (default: cover page-01)
//   topbarVariant — 'default' | 'minimal' (minimal hides nav links)

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  topbarVariant?: 'default' | 'minimal';
}

const {
  title,
  description = 'Portfolio von Jule Plaehn — Textile Design /26. Krefeld. Nutritions, (Objekt) siebzig, Freie Arbeiten.',
  ogImage = 'https://pub-45145834ff2b45db8a585cff5b669e13.r2.dev/page-01-1520w.jpg',
  topbarVariant = 'default',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Jule Plaehn" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="alternate" type="application/xml" href={`${base}/sitemap.xml`} />

  <!-- Open Graph -->
  <meta property="og:type" content="profile" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="de_DE" />
  <meta property="profile:first_name" content="Jule" />
  <meta property="profile:last_name" content="Plaehn" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://pub-45145834ff2b45db8a585cff5b669e13.r2.dev" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;1,400&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400;1,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

<header class="topbar">
  <a class="brand" href={`${base}/`}>jule plaehn</a>
  {topbarVariant === 'default' && (
    <nav class="topnav" aria-label="Hauptnavigation">
      <a href={`${base}/work/sauer-1`}>/sauer-1</a>
      <a href={`${base}/print`}>/print</a>
    </nav>
  )}
</header>

<main>
  <slot />
</main>

<style is:global>
  @import "../styles/tokens.css";

  .topbar {
    position: fixed; inset: 0 0 auto 0; height: 48px; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 22px;
    background: rgba(255, 255, 255, .86);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--hair);
    font-family: var(--font-mono); font-size: 12px; letter-spacing: .04em;
    color: var(--ink);
  }
  .topbar .brand {
    font-family: var(--font-display); font-style: italic;
    font-size: 17px; color: var(--red-text);
  }
  .topbar .topnav { display: flex; gap: 22px; align-items: center; }
  .topbar .topnav a {
    border-bottom: 1px solid transparent; padding-bottom: 1px;
    transition: border-color .15s ease;
  }
  .topbar .topnav a:hover, .topbar .topnav a:focus-visible {
    border-color: var(--red); outline: none;
  }
  main { padding-top: 48px; }

  @media (max-width: 820px) {
    .topbar { padding: 0 12px; }
    .topbar .topnav { display: none; }
  }
</style>

</body>
</html>
